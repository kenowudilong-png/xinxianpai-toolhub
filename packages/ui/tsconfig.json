{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./@/*", "./src/*"]
    }
  },
  "include": ["@/**/*.ts", "@/**/*.tsx", "src/**/*.ts", "src/**/*.tsx"]
}

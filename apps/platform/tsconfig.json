{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "preserve",
    "module": "ESNext",
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@xinxianpai/shared": ["../../packages/shared/src/index.ts"],
      "@xinxianpai/db": ["../../packages/db/src/index.ts"],
      "@xinxianpai/storage": ["../../packages/storage/src/index.ts"]
    },
    "isolatedModules": true,
    "strict": true
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts", "../../packages/*/src/**/*.ts"],
  "exclude": ["node_modules"]
}
